project:
  type: website
  output-dir: docs
  render:
    - index.qmd
    - about.qmd
    - install.qmd
    - numcosmo-math-api.qmd
    - numcosmo-api.qmd
    - theory/csq1d.qmd
    - theory/distances.qmd
    - theory/recombination.qmd
    - theory/transfer_func_eh.qmd
    - theory/wl_surface_mass_density.qmd
    - benchmarks/ccl_background.qmd
    - benchmarks/ccl_power_spectrum.qmd
    - benchmarks/ccl_two_point.qmd
    - tutorials/c/gobject.qmd
    - tutorials/c/curve_tutorial.qmd
    - tutorials/python/bounce.qmd
    - tutorials/python/bounce_spectra.qmd
    - tutorials/python/cluster_wl_simul.qmd
    - tutorials/python/halo_catalog_mock.qmd
    - tutorials/python/sky_match.qmd
    - tutorials/python/sky_match_id.qmd
    - examples/data_analysis/inspect_data_objects.qmd
    - examples/data_analysis/snia.qmd
    - examples/intro/epdf.qmd
    - examples/intro/hiprim.qmd
    - examples/intro/hiprim_tensor.qmd
    - examples/intro/power_spectrum.qmd
    - examples/intro/recombination.qmd
    - examples/intro/simple.qmd
    - examples/intro/wspline.qmd
  post-render:
    - ./ipynb_to_py.sh

execute:
  error: false
  freeze: auto

website:
  title: "The Numerical Cosmology Library"
  favicon: images/favicon_numcosmo.png
  cookie-consent:
    type: express
    style: headline
    palette: dark
  google-analytics:
    tracking-id: "G-ZRWDDX4BLS"
    anonymize-ip: true
  navbar:
    search: true
    tools:
      - icon: github
        menu:
          - text: "Source Code"
            href: https://github.com/NumCosmo/NumCosmo
          - text: "Issues"
            href: https://github.com/NumCosmo/NumCosmo/issues
    left:
      - about.qmd
      - install.qmd
      - text: "NumCosmoMath"
        href: reference/numcosmo-math/index.html
      - text: "NumCosmo"
        href: reference/numcosmo/index.html
  sidebar:
      style: "docked"
      logo: images/numcosmo_logo.png
      collapse-level: 2
      contents:
        - section: "Getting Started"
          contents:
            - href: install.qmd
              text: "Installation"
            - href: examples/intro/simple.qmd
              text: "First Steps"
        - section: "Tutorials"
          contents:
            - href: tutorials/c/gobject.qmd
              text: "GObject in C"
            - href: tutorials/c/curve_tutorial.qmd
              text: "Model Fitting in C"
        - section: "Theory"
          contents:
            - href: theory/distances.qmd
              text: "Cosmological Distances"
            - href: theory/recombination.qmd
              text: "Cosmic Recombination"
            - href: theory/transfer_func_eh.qmd
              text: "Eisenstein–Hu Transfer Function"
            - href: theory/wl_surface_mass_density.qmd
              text: "Weak-Lensing Surface Mass Density"
            - href: theory/csq1d.qmd
              text: "CSQ1D Formalism"
        - section: "Worked Examples"
          contents:
            - section: "Background & Distances"
              contents:
              - href: examples/intro/wspline.qmd
                text: "Dark Energy WSpline"
              - href: examples/intro/recombination.qmd
                text: "Recombination"
            - section: "Large-Scale Structure"
              contents:
              - href: examples/intro/power_spectrum.qmd
                text: "Matter Power Spectrum"
            - section: "Primordial & Bouncing"
              contents:
              - href: examples/intro/hiprim.qmd
                text: "Primordial Modeling"
              - href: examples/intro/hiprim_tensor.qmd
                text: "Primordial Tensor Contribution"
              - href: tutorials/python/bounce.qmd
                text: "Bounce Adiabatic Spectrum"
              - href: tutorials/python/bounce_spectra.qmd
                text: "Bounce Two-Fluid Spectra"
            - section: "Clusters & Weak Lensing"
              contents:
              - href: tutorials/python/cluster_wl_simul.qmd
                text: "Cluster WL Simulation"
              - href: tutorials/python/halo_catalog_mock.qmd
                text: "Halo Catalog Mock"
            - section: "Catalogs & Matching"
              contents:
              - href: tutorials/python/sky_match.qmd
                text: "Sky Match"
              - href: tutorials/python/sky_match_id.qmd
                text: "Sky Match by Membership"
            - section: "Data & Statistics"
              contents:
              - href: examples/data_analysis/snia.qmd
                text: "SN Ia Fitting"
              - href: examples/data_analysis/inspect_data_objects.qmd
                text: "Inspect Data Objects"
              - href: examples/intro/epdf.qmd
                text: "Empirical PDF"
        - section: "Validation"
          contents:
            - href: benchmarks/ccl_background.qmd
              text: "CCL Background"
            - href: benchmarks/ccl_power_spectrum.qmd
              text: "CCL Power Spectrum"
            - href: benchmarks/ccl_two_point.qmd
              text: "CCL Two-Point Correlation"

resources:
  - reference/**

bibliography: references.bib

format:
  html:
    theme: [serif, custom.scss]
    filters:
      - linkgen.lua
    toc: true
    code-overflow: wrap
    grid:
      body-width: 1200px
    include-after-body:
      - add-py-link.html
  ipynb:
    filters:
      - ipynb-strip-xref.lua
    execute:
      eval: false
      echo: true
      output: true
reference-location: margin
citation-location: margin
authors:
  - NumCosmo developers
jupyter: python3
version: @version@
